{
	"name": "@ginjou/monorepo",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@11.2.2",
	"author": "zhong666 <hi@zhong666.me>",
	"license": "MIT",
	"scripts": {
		"build:pkgs": "turbo run build --filter='./packages/*'",
		"build:sb": "turbo run build --filter='./stories/*'",
		"build:docs": "turbo run build --filter=@ginjou/docs",
		"preview:sb": "turbo run preview --filter=@ginjou/storybook",
		"preview:docs": "turbo run preview --filter=@ginjou/docs",
		"test": "run-s --silent test:prepare \"test:run {@}\" --",
		"test:prepare": "pnpm --filter @ginjou/nuxt build:prepare",
		"test:run": "vitest run",
		"bench": "vitest bench --run --project benchmark",
		"dev:sb": "turbo run dev --filter='./stories/*'",
		"dev:nuxt": "turbo run dev --filter=@ginjou/nuxt",
		"dev:docs": "turbo run dev --filter=@ginjou/docs",
		"release:pkgs": "turbo run release --concurrency=1 --filter='./packages/*'",
		"lint": "eslint . --cache --cache-location ./node_modules/.cache/eslint",
		"typecheck:pkgs": "turbo run typecheck --filter='./packages/*'"
	},
	"devDependencies": {
		"@aa900031/eslint-config": "^8.0.0",
		"@aa900031/release-it-config": "^1.0.0",
		"@codspeed/vitest-plugin": "^5.7.1",
		"@types/node": "^24.3.1",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"happy-dom": "^20.11.0",
		"npm-run-all2": "^9.0.2",
		"release-it": "^20.2.1",
		"sirv-cli": "^3.0.1",
		"svelte-check": "^4.7.3",
		"turbo": "^2.10.5",
		"typescript": "^5.9.3",
		"vitest": "^4.1.10",
		"vue-tsc": "^3.3.7"
	}
}
