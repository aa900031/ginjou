{
	"name": "@ginjou/storybook-svelte",
	"type": "module",
	"private": true,
	"author": "zhong666 <hi@zhong666.me>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aa900031/ginjou"
	},
	"bugs": {
		"url": "https://github.com/aa900031/ginjou/issues"
	},
	"scripts": {
		"dev": "run-s --silent dev:prepare dev:sb",
		"dev:prepare": "msw init ./public --save",
		"dev:sb": "storybook dev -p 6008 --no-open",
		"build": "run-s --silent build:prepare build:sb",
		"build:prepare": "msw init ./public --save",
		"build:sb": "storybook build -o ../root/dist/svelte"
	},
	"devDependencies": {
		"@ginjou/core": "workspace:^",
		"@ginjou/storybook-shared": "workspace:*",
		"@ginjou/svelte": "workspace:*",
		"@ginjou/tsconfig": "workspace:*",
		"@ginjou/with-rest-api": "workspace:*",
		"@ginjou/with-svelte-spa-router": "workspace:*",
		"@storybook/addon-docs": "10.4.1",
		"@storybook/svelte-vite": "10.4.1",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tanstack/svelte-query": "^6.1.32",
		"msw": "^2.14.6",
		"storybook": "10.4.1",
		"svelte": "^5.25.0",
		"svelte-spa-router": "^5.1.0",
		"unocss": "^66.7.0",
		"vite": "^7.3.3"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
