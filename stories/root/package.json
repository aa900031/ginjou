	},
	"bugs": {
		"url": "https://github.com/aa900031/ginjou/issues"
	},
	"scripts": {
		"dev": "run-s --silent dev:wait dev:storybook",
		"dev:wait": "run-p 'dev:wait-*'",
		"dev:wait-svelte": "wait-on tcp:6008",
		"dev:wait-vue": "wait-on tcp:6007",
		"dev:storybook": "storybook dev -p 6006 --no-open",
		"build": "storybook build -o dist",
		"preview": "sirv ./dist --host -p 7006"
	},
	"devDependencies": {
		"@ginjou/storybook-shared": "workspace:*",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/react-vite": "^10.4.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"remark-gfm": "^4.0.1",
		"storybook": "^10.4.1",
		"vite": "^7.3.3",
		"wait-on": "^9.0.10"
	}
}
